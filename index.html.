<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi página wed privada</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .container { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center; }
        input, button { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; }
        button { background: #28a745; color: white; border: none; cursor: pointer; font-weight: bold; }
        button:hover { background: #218838; }
        #app { display: none; }
        #qrcode { margin-top: 20px; display: flex; justify-content: center; flex-direction: column; align-items: center; }
        img { max-width: 100%; border-radius: 8px; margin-top: 10px; border: 1px solid #eee; }
        .logout-btn { background: #dc3545; margin-top: 20px; }
    </style>
</head>
<body>

<div class="container" id="login-box">
    <h2>Acceso Privado</h2>
    <p>Introduce tu clave para continuar</p>
    <input type="password" id="password" placeholder="Clave de acceso">
    <button onclick="checkLogin()">Entrar</button>
</div>

<div class="container" id="app">
    <h2>Panel de Control</h2>
    <p>Sube una imagen para verla y crear su QR</p>
    <input type="file" id="fileInput" accept="image/*" onchange="previewImage()">
    <div id="preview"></div>
    <button onclick="generateQR()">Generar Código QR</button>
    <div id="qrcode"></div>
    <button class="logout-btn" onclick="logout()">Cerrar Sesión</button>
</div>

<script>
    // Tu nueva clave personalizada
    const CLAVE_CORRECTA = "18712529"; 

    function checkLogin() {
        const pass = document.getElementById('password').value;
        if (pass === CLAVE_CORRECTA) {
            document.getElementById('login-box').style.display = 'none';
            document.getElementById('app').style.display = 'block';
        } else {
            alert("Clave incorrecta. Inténtalo de nuevo.");
        }
    }

    function previewImage() {
        const file = document.getElementById('fileInput').files[0];
        const preview = document.getElementById('preview');
        preview.innerHTML = '';
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                preview.appendChild(img);
            }
            reader.readAsDataURL(file);
        }
    }

    function generateQR() {
        const qrContainer = document.getElementById("qrcode");
        qrContainer.innerHTML = ''; 
        const file = document.getElementById('fileInput').files[0];
        
        if (!file) {
            alert("Por favor, selecciona una imagen primero.");
            return;
        }

        // Creamos el QR con el nombre del archivo
        new QRCode(qrContainer, {
            text: "Archivo: " + file.name,
            width: 150,
            height: 150
        });
        
        const label = document.createElement('p');
        label.innerText = "QR generado para: " + file.name;
        label.style.fontSize = "12px";
        qrContainer.appendChild(label);
    }

    function logout() {
        location.reload();
    }
</script>

</body>
</html>
